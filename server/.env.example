VITE_PORT=8080
VITE_API_URL=http://localhost:8080

# create cluster and database user in MongoDB Atlas (free tier), then set the connection string here (Use the non-SRV format from Atlas and include the replica set and authSource parameters)
# +srv requires DNS SRV lookup.
# https://www.mongodb.com/products/platform/atlas-database 

MONGODB_URI=mongodb://<username>:<url-encoded-password>@<host1>:27017,<host2>:27017,<host3>:27017/?ssl=true&replicaSet=<replicaSetName>&authSource=admin&retryWrites=true&w=majority&appName=Cluster0

# Run 'npm run seed' to create the db and seed it with sample data (seed.js)

OPENROUTER_API_KEY=sk-or-...

# Optional:
# JWT_SECRET=change-me
# SITE_URL=http://localhost:5173
# SITE_TITLE=Patiently
